# Supabase — get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Site URL for password reset links. Use http://localhost:3000 for local dev.
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Optional: WhatsApp number for Job Vacancies page (digits only, with country code, e.g. 6581234567)
# NEXT_PUBLIC_JOBS_WHATSAPP=6581234567

# Footer social icons
# Option A — one handle for Facebook, Instagram, and X (no @). Used when the per-platform URLs below are unset:
NEXT_PUBLIC_SOCIAL_BRAND_HANDLE=thekitchenconnection
# Option B — override any platform with full https URLs:
# NEXT_PUBLIC_SOCIAL_FACEBOOK=https://www.facebook.com/yourpage
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://www.instagram.com/yourprofile
# NEXT_PUBLIC_SOCIAL_LINKEDIN=https://www.linkedin.com/company/yourcompany
# NEXT_PUBLIC_SOCIAL_YOUTUBE=https://www.youtube.com/@yourchannel
# NEXT_PUBLIC_SOCIAL_TWITTER=https://x.com/yourhandle
# NEXT_PUBLIC_SOCIAL_X=https://x.com/yourhandle

# OpenAI — REQUIRED for: (a) site chatbot, (b) auto_post.py bilingual
# summaries, (c) auto_post.py DALL·E image generation.
# NOT required for manually creating news articles from the admin dashboard.
# Add the key below — chatbot, news automation, and Instagram pipeline will
# all pick it up automatically (legacy aliases below are also accepted).
OPENAI_API_KEY=sk-...
# Legacy aliases supported by code (any one of these works; prefer OPENAI_API_KEY):
# OPENAPI_API_KEY=
# openai_api_key=
# OPENAI_MODEL=gpt-4o-mini
# Optional base URL for Azure OpenAI or other proxies:
# OPENAI_API_BASE=https://api.openai.com/v1

# Optional: persist chatbot Q&A to Supabase (requires scripts/chatbot_logs.sql)
# ENABLE_CHATBOT_LOGGING=true

# Video transcoding callback auth (used by /api/videos/transcode/callback)
# VIDEO_TRANSCODE_WEBHOOK_SECRET=change-me-to-a-long-random-value

# Contact form: SMTP (emails sent to CONTACT_EMAIL_TO)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-app-password
CONTACT_EMAIL_TO=your-inbox@example.com

# Slack Incoming Webhook used by auto_post.py to report run status.
# Leave blank to disable Slack notifications.
SLACK_WEBHOOK_URL=

# ─── auto_post.py: News retrieval sources ───────────────────────────────────
# URLs the daily collector crawls.  Each is optional — leave a line unset to
# fall back to the in-code default in auto_post.py:DEFAULT_SOURCES.
#
# RSS feeds (feedparser)
NEWS_RSS_INDUSTRY=https://news.google.com/rss/search?q=Singapore+food+beverage&hl=en-SG&gl=SG&ceid=SG:en
NEWS_RSS_EVENT=https://news.google.com/rss/search?q=Singapore+restaurant+opening&hl=en-SG&gl=SG&ceid=SG:en
NEWS_RSS_REGULATION=https://news.google.com/rss/search?q=%22Singapore+Food+Agency%22&hl=en-SG&gl=SG&ceid=SG:en
NEWS_RSS_TREND=https://news.google.com/rss/search?q=Singapore+food+trend&hl=en-SG&gl=SG&ceid=SG:en
# Static listing pages (BeautifulSoup)
NEWS_URL_REGULATION=https://www.sfa.gov.sg/food-for-thought/article/detail/safe-framework---strengthening-food-safety-together--one-grade-at-a-time
NEWS_URL_EVENT=https://www.timeout.com/singapore/restaurants/new-restaurants-in-singapore
NEWS_URL_TREND=https://danielfooddiary.com/category/singapore/
# Power-user: replace EVERYTHING with a JSON array.
# NEWS_SOURCES_JSON=[{"name":"My feed","rss":"https://example.com/rss","category":"industry"}]
